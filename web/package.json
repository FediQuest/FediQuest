{
  "name": "fediquest-web",
  "version": "1.0.0",
  "description": "FediQuest WebAR Demo - A-Frame + AR.js GPS-based AR experience",
  "main": "index.html",
  "scripts": {
    "start": "npx http-server -p 8080 -c-1 --cors",
    "serve": "python3 -m http.server 8080",
    "clean-cache": "npm cache clean --force && rm -rf node_modules"
  },
  "keywords": [
    "ar",
    "augmented-reality",
    "gps",
    "aframe",
    "arjs",
    "webar",
    "fediquest",
    "foss"
  ],
  "author": "FediQuest Contributors",
  "license": "MIT",
  "devDependencies": {
    "http-server": "^14.1.1"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fediquest/fediquest.git"
  }
}
