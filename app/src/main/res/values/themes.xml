<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme -->
    <style name="Theme.FediQuest" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/color_primary</item>
        <item name="colorPrimaryVariant">@color/color_primary_dark</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        
        <!-- Secondary/accent color -->
        <item name="colorSecondary">@color/color_accent</item>
        <item name="colorSecondaryVariant">@color/color_primary_dark</item>
        <item name="colorOnSecondary">@color/text_on_primary</item>
        
        <!-- Background colors -->
        <item name="android:colorBackground">@color/background_primary</item>
        <item name="colorSurface">@color/background_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        
        <!-- Status bar -->
        <item name="android:statusBarColor">@color/color_primary_dark</item>
        <item name="android:navigationBarColor">@color/color_primary_dark</item>
        
        <!-- Window -->
        <item name="android:windowBackground">@color/background_primary</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>

    <!-- Dark theme variant -->
    <style name="Theme.FediQuest.Dark" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/color_primary_light</item>
        <item name="colorPrimaryVariant">@color/color_primary</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        
        <item name="colorSecondary">@color/color_accent</item>
        <item name="colorOnSecondary">@color/text_on_primary</item>
        
        <item name="android:colorBackground">@color/dark_background_primary</item>
        <item name="colorSurface">@color/dark_background_card</item>
        <item name="colorOnSurface">@color/dark_text_primary</item>
        
        <item name="android:statusBarColor">@color/dark_background_secondary</item>
        <item name="android:navigationBarColor">@color/dark_background_secondary</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.FediQuest.Splash" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowBackground">@color/color_primary</item>
        <item name="android:statusBarColor">@color/color_primary</item>
        <item name="android:navigationBarColor">@color/color_primary</item>
    </style>

    <!-- Button styles -->
    <style name="Widget.FediQuest.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/color_primary</item>
        <item name="android:textColor">@color/text_on_primary</item>
    </style>

    <style name="Widget.FediQuest.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/color_primary</item>
        <item name="android:textColor">@color/color_primary</item>
    </style>

    <style name="Widget.FediQuest.Button.Accent" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/color_accent</item>
        <item name="android:textColor">@color/text_on_primary</item>
    </style>

    <!-- Card style -->
    <style name="Widget.FediQuest.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/background_card</item>
        <item name="cardElevation">4dp</item>
        <item name="cardCornerRadius">12dp</item>
    </style>

    <!-- XP Progress Bar -->
    <style name="Widget.FediQuest.ProgressBar.XP" parent="Widget.AppCompat.ProgressBar.Horizontal">
        <item name="android:progressDrawable">@drawable/progress_xp</item>
        <item name="android:max">100</item>
    </style>

    <!-- Text styles -->
    <style name="TextAppearance.FediQuest.Headline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.FediQuest.Title" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.FediQuest.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.FediQuest.Caption" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">@color/text_hint</item>
    </style>

    <!-- Bottom Navigation -->
    <style name="Widget.FediQuest.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="backgroundColor">@color/background_card</item>
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>
</resources>
